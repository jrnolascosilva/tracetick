!backend/gradle/wrapper/gradle-wrapper.jar

# Gradle
.gradle/
backend/.gradle/
!**/src/main/**/build/
!**/src/test/**/build/

# Node
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
